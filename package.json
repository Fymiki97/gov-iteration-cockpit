{
  "name": "@wps365-open/boilerplate",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "run-p dev:client dev:server",
    "dev:client": "pnpm --filter @wps365-open/boilerplate-client dev",
    "dev:server": "pnpm --filter @wps365-open/boilerplate-server dev",
    "pack": "run-p pack:frontend pack:server",
    "pack:frontend": "pnpm --filter @wps365-open/boilerplate-client pack:frontend",
    "pack:server": "pnpm --filter @wps365-open/boilerplate-server pack:server",
    "lint": "run-p lint:client lint:server",
    "lint:client": "pnpm --filter @wps365-open/boilerplate-client lint",
    "lint:server": "pnpm --filter @wps365-open/boilerplate-server lint",
    "build": "run-p build:client build:server",
    "build:client": "pnpm --filter @wps365-open/boilerplate-client build",
    "build:server": "pnpm --filter @wps365-open/boilerplate-server build",
    "check:types": "run-p check:types:client check:types:server",
    "check:types:client": "pnpm --filter @wps365-open/boilerplate-client check:types",
    "check:types:server": "pnpm --filter @wps365-open/boilerplate-server check:types"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "npm-run-all": "^4.1.5",
    "pptxgenjs": "^4.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher",
      "lightningcss",
      "msw"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}